{
  "name": "vault-tasks",
  "version": "0.3.0",
  "description": "Markdown-file task manager for solo devs building with Claude Code",
  "type": "module",
  "bin": {
    "vault-tasks": "./dist/cli.js",
    "vt": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "files": [
    "dist",
    "!dist/tests",
    "templates",
    "src",
    "!src/tests"
  ],
  "scripts": {
    "build": "tsc",
    "test": "node --test dist/tests/*.test.js",
    "prepublishOnly": "npm run build && npm test"
  },
  "keywords": [
    "tasks",
    "backlog",
    "obsidian",
    "claude-code",
    "markdown",
    "zettelkasten",
    "second-brain"
  ],
  "author": "Adam Cohn",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/adcoh/vault-tasks.git"
  },
  "homepage": "https://github.com/adcoh/vault-tasks#readme",
  "bugs": {
    "url": "https://github.com/adcoh/vault-tasks/issues"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "typescript": "^5.8.0"
  }
}
