{
  "name": "vault-tasks",
  "version": "0.1.0",
  "description": "Markdown-file task manager for solo devs building with Claude Code",
  "type": "module",
  "bin": {
    "vault-tasks": "./dist/cli.js",
    "vt": "./dist/cli.js"
  },
  "exports": {
    ".": "./dist/index.js"
  },
  "files": [
    "dist",
    "templates"
  ],
  "scripts": {
    "build": "tsc",
    "test": "node --test dist/tests/*.test.js",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "tasks",
    "backlog",
    "obsidian",
    "claude-code",
    "markdown",
    "zettelkasten",
    "second-brain"
  ],
  "author": "Adam Cohn",
  "license": "MIT",
  "engines": {
    "node": ">=22.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "typescript": "^5.8.0"
  }
}
